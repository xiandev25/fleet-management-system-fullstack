# =========================================================================
# Django Backend - Local Environment Configuration Example
# Copy this file to '.env' and fill in your private credentials.
# =========================================================================

# Django Core Security Settings
# (Use a strong unique key in production!)
SECRET_KEY=django-insecure-your-secret-key-goes-here-make-it-secure-123

# Toggle Debug Mode (True for local development, False for production)
DEBUG=True

# Allowed Hosts (comma-separated list of hostnames)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (PostgreSQL credentials)
DB_NAME=fleet_flow_db
DB_USER=fleet_user
DB_PASSWORD=fleet_pass
DB_HOST=localhost
DB_PORT=5432
